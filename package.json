{
  "name": "wedscene-ai-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./assets/styles.css --content ./index.html --minify",
    "build:site": "node scripts/build-site.mjs",
    "build": "npm run build:css && npm run build:site",
    "build:deploy": "npm run build && node scripts/build-deploy-package.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preview:motion-prompt": "node scripts/preview-motion-prompt.mjs",
    "generate:motion-direct": "node scripts/generate-motion-video-direct.mjs",
    "start": "node --env-file=.env server.mjs",
    "start:prod": "node --env-file=.env server.mjs",
    "start:proxy": "node --env-file=.env --use-env-proxy server.mjs",
    "preview": "serve dist",
    "static": "serve ."
  },
  "devDependencies": {
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "multer": "^2.1.1",
    "openai": "^6.39.0",
    "opentype.js": "^2.0.0",
    "sharp": "^0.34.5"
  }
}
