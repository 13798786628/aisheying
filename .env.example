PORT=5173
NODE_ENV=production
IMAGE_PROVIDER=n1n
OPENAI_API_KEY=replace_with_your_n1n_key
OPENAI_BASE_URL=https://llm-api.net/v1
OPENAI_PROVIDER_LABEL=n1n.ai
OPENAI_IMAGE_MODEL=gpt-image-2-all
OPENAI_IMAGE_FALLBACK_MODELS=gpt-image-2
N1N_IMAGE_INPUT_MODE=auto
N1N_STRICT_REFERENCE_FALLBACK=fail
ALLOW_XIAOJI_IMAGE_PROVIDER=false
ALLOW_XIAOJI_IMAGE_FALLBACK=false
N1N_IMAGE_EDIT_ENDPOINT=https://llm-api.net/v1/images/edits
N1N_IMAGE_GENERATIONS_ENDPOINT=https://llm-api.net/v1/images/generations
FREE_IMAGE_REFERENCE_LIMIT=8
# Xiaoji/baziapi image relay is intentionally disabled in server.mjs.
# Do not set IMAGE_PROVIDER=xiaoji or XIAOJI_API_KEY.
OPENAI_IMAGE_QUALITY=high
FINAL_IMAGE_JPEG_QUALITY=95
FINAL_BOARD_JPEG_QUALITY=94
FINAL_BOARD_CELL_JPEG_QUALITY=94
OPENAI_REQUEST_TIMEOUT_MS=600000
# 设计图转实景单张图独立超时，避免上游单图生成长时间卡住
# DESIGN_RENDER_IMAGE_TIMEOUT_MS=180000
# DESIGN_RENDER_MAX_ATTEMPTS=1
# DESIGN_RENDER_CONCURRENCY=1
ENABLE_COPY_API=true
COPY_MODEL=gpt-4.1
CHAT_MODEL=gpt-5.5
CHAT_API_ENDPOINT=https://llm-api.net/v1/chat/completions
CHAT_REQUEST_TIMEOUT_MS=180000
CHAT_JSON_BODY_LIMIT=32mb
CHAT_IMAGE_LIMIT=6
CHAT_POINT_COST=1
MOTION_DIRECTOR_MODEL=gpt-4.1
DOUBAO_VIDEO_PROMPT_MODEL=doubao-seed-2-0-lite-260428
COPY_REQUEST_TIMEOUT_MS=120000
# Optional local proxy. Keep these commented on cloud servers unless a proxy is required.
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
NO_PROXY=127.0.0.1,localhost
REFERENCE_IMAGE_MAX_EDGE=1280
REFERENCE_IMAGE_QUALITY=86
STORYBOARD_IMAGE_SIZE=1536x864
CONSTRUCTION_CHECKLIST_IMAGE_SIZE=1536x864
CONSTRUCTION_CHECKLIST_HD_WIDTH=4096
CONSTRUCTION_CHECKLIST_DETAIL_EXPORTS=true
USE_MOCK_IMAGES=false
MOTION_VIDEO_PROVIDER=pro666
MOTION_VIDEO_MODEL=wf-sd2-fast
MOTION_VIDEO_ENDPOINT=https://api.pro666.top/v1/videos
# pro666 video-v1 uses Authorization: Bearer YOUR_API_KEY.
MOTION_VIDEO_API_KEY=replace_with_pro666_api_key
MOTION_VIDEO_FALLBACK_MODELS=
MOTION_REFERENCE_LIMIT=3
MOTION_VIDEO_DURATION=15
MOTION_VIDEO_RESOLUTION=
MOTION_VIDEO_SIZE=1280x720
MOTION_VIDEO_ASPECT_RATIO=16:9
MOTION_VIDEO_POLL_INTERVAL_MS=5000
MOTION_VIDEO_STALL_RETRY_MS=300000
MOTION_VIDEO_MAX_SUBMIT_ATTEMPTS=1

# 豆包/千问素材导入。先单独部署 ihmily/doubao-nomark，再把地址填到这里。
# 本机运行示例：uvicorn app:app --host 127.0.0.1 --port 8000
DOUBAO_NOMARK_API_BASE=http://127.0.0.1:8000
DOUBAO_NOMARK_TIMEOUT_MS=120000
EXTERNAL_IMPORT_MAINTENANCE=true
EXTERNAL_IMPORT_VIDEO_WATERMARK_REMOVE=false
EXTERNAL_IMPORT_MAX_ASSETS=12
# Max Doubao/Qianwen share links accepted in one batch import.
EXTERNAL_IMPORT_MAX_LINKS=6
# Max bytes for each asset downloaded from the parser response.
EXTERNAL_IMPORT_MAX_ASSET_BYTES=157286400
# Optional comma-separated host allowlist for parser-returned assets, for example:
# EXTERNAL_IMPORT_ALLOWED_HOSTS=doubao.com,byteimg.com,qianwen.com

# 本地声音克隆旁白。先启动 GPT-SoVITS API，再填这里。
# GPT-SoVITS 常见本机地址示例：http://127.0.0.1:9880
# VOICE_CLONE_PROVIDER=gpt-sovits
# VOICE_CLONE_API_BASE=http://127.0.0.1:9880
# VOICE_CLONE_TTS_PATH=/tts
# VOICE_CLONE_TEXT_LANG=all_zh
# VOICE_CLONE_PROMPT_LANG=all_zh
# VOICE_CLONE_TIMEOUT_MS=180000
# VOICE_CLONE_MAX_AUDIO_BYTES=52428800

# Basic abuse throttles. Tune higher only after CDN/WAF protection is in place.
# LOGIN_IP_LIMIT=20
# LOGIN_IP_WINDOW_MS=900000
# ADMIN_IP_LIMIT=30
# ADMIN_IP_WINDOW_MS=900000
# GENERATE_IP_LIMIT=60
# GENERATE_IP_WINDOW_MS=3600000
# EXTERNAL_IMPORT_IP_LIMIT=20
# EXTERNAL_IMPORT_IP_WINDOW_MS=3600000

# Optional public beta gate. Leave empty for local development.
# When set, visitors must enter this code before generating or viewing resources.
# PUBLIC_ACCESS_CODE=replace_with_private_beta_code
# ACCESS_TOKEN_SECRET=replace_with_random_server_secret
# ACCESS_COOKIE_SECURE=false

# Saved resource retention. Defaults are 30 records per owner for 7 days.
# RESOURCE_RETENTION_LIMIT=30
# RESOURCE_RETENTION_DAYS=7
# RESOURCE_CLEANUP_INTERVAL_MS=86400000
# RESOURCE_CLEANUP_ON_STARTUP=true

# 1.0 manual recharge account system. Enable this before public beta.
# Customers log in with an 11-digit phone number and password.
# ACCOUNT_SYSTEM_ENABLED=true
# ACCOUNT_TOKEN_SECRET=replace_with_random_account_secret
# ACCOUNT_COOKIE_SECURE=false
# SUPPORT_WECHAT=your_wechat_id
# SUPPORT_WECHAT_QR=/assets/wechat-qr-clean.png
# SUPPORT_WECHAT_2=backup_wechat_id
# SUPPORT_WECHAT_QR_2=/assets/wechat-qr-backup-clean.png
# Phone SMS verification for self-registration. This version keeps it off by default:
# customers register with an 11-digit phone number plus password, without an SMS code.
# Turn PHONE_VERIFICATION_REQUIRED=true back on after the SMS provider is ready.
# Local debugging only: SMS_PROVIDER=log plus SMS_DEBUG_LOG_CODE=true will print the code in server logs.
# PHONE_VERIFICATION_REQUIRED=false
# SMS_PROVIDER=smsbao
# SMS_DEBUG_LOG_CODE=false
# PHONE_CODE_TTL_SECONDS=300
# PHONE_CODE_RESEND_SECONDS=60
# SMSBAO_USERNAME=replace_with_smsbao_username
# SMSBAO_PASSWORD_MD5=replace_with_md5_password
# SMSBAO_SIGN_NAME=replace_with_approved_sms_sign_name
# SMSBAO_TEMPLATE=您的验证码是{code}，{minutes}分钟内有效，请勿泄露。
# TENCENT_SMS_SECRET_ID=replace_with_tencent_secret_id
# TENCENT_SMS_SECRET_KEY=replace_with_tencent_secret_key
# TENCENT_SMS_SDK_APP_ID=replace_with_sms_sdk_app_id
# TENCENT_SMS_SIGN_NAME=replace_with_approved_sms_sign_name
# TENCENT_SMS_TEMPLATE_ID=replace_with_approved_template_id
# TENCENT_SMS_REGION=ap-guangzhou
# TRIAL_POINTS=5
# JOB_POINT_COST=5
# TEXT_POINT_COST=1
# PLAN_IMAGE_POINT_COST=10
# IMAGE_ENHANCE_POINT_COST=5
# SIX_IMAGE_POINT_COST=30
# STORYBOARD_POINT_COST=50
# DESIGN_RENDER_POINT_COST=5
# Recharge plans are shown in the user recharge dialog and admin quick recharge.
# Format: price=points;price=points. The default profile names/badges are attached by price.
# RECHARGE_PLANS=29.9元=300灵感值;299元=3000灵感值;899元=11000灵感值;3980元=高级代理权益包
# ADMIN_TOKEN=replace_with_private_admin_token

# 1.0 public beta placeholders. Current app still uses local .data storage;
# fill these when the account, database, and cloud storage layer is implemented.
# DATABASE_URL=mysql://user:password@host:3306/wedscene
# STORAGE_PROVIDER=cos
# TENCENT_COS_BUCKET=replace_with_bucket
# TENCENT_COS_REGION=ap-shanghai
# TENCENT_COS_SECRET_ID=replace_with_secret_id
# TENCENT_COS_SECRET_KEY=replace_with_secret_key
# APP_PUBLIC_URL=https://your-domain.com

# Default edit mode sends the uploaded photo as a multipart reference image.

# To use the official OpenAI Images API:
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_openai_key
# OPENAI_IMAGE_MODEL=gpt-image-2

# To use n1n.ai's OpenAI-compatible endpoint:
# IMAGE_PROVIDER=n1n
# OPENAI_API_KEY=replace_with_your_n1n_key
# OPENAI_BASE_URL=https://api.n1n.ai/v1
# OPENAI_PROVIDER_LABEL=n1n.ai
# OPENAI_IMAGE_MODEL=gpt-image-2-all
# OPENAI_IMAGE_FALLBACK_MODELS=gpt-image-2
# IMAGE_ENHANCE_MODEL=gemini-3.1-flash-image
# IMAGE_ENHANCE_FALLBACK_MODELS=
# DEFAULT_IMAGE_ENHANCE_SIZE=2K
# N1N_IMAGE_INPUT_MODE=auto
# N1N_IMAGE_EDIT_ENDPOINT=https://api.n1n.ai/v1/images/edits
# N1N_IMAGE_GENERATIONS_ENDPOINT=https://api.n1n.ai/v1/images/generations
# HTTPS_PROXY=http://127.0.0.1:7897

# Official Gemini generateContent API for the image enhance mode.
# Required when IMAGE_ENHANCE_MODEL is gemini-3.1-flash-image and 2K/4K output is needed.
# GEMINI_API_KEY=replace_with_your_gemini_key
# IMAGE_ENHANCE_PROVIDER=gemini
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1
# Leave GEMINI_IMAGE_ENDPOINT empty unless Google changes the generateContent URL.

# pro666 video-v1 endpoint. The server sends public reference image URLs to /v1/videos.
# PUBLIC_BASE_URL must be a publicly reachable HTTPS origin so pro666 can fetch reference images.
# PUBLIC_BASE_URL=https://your-public-domain.example
# API_CORS_ORIGINS should include every static site origin that calls this API.
# API_CORS_ORIGINS=https://your-github-username.github.io,https://your-site.netlify.app,https://your-project.vercel.app
# MOTION_VIDEO_PROVIDER=pro666
# MOTION_VIDEO_MODEL=wf-sd2-fast
# MOTION_VIDEO_ENDPOINT=https://api.pro666.top/v1/videos
# MOTION_VIDEO_API_KEY=replace_with_pro666_api_key
# MOTION_REFERENCE_LIMIT=3
# MOTION_VIDEO_DURATION=15
# MOTION_VIDEO_RESOLUTION=
# MOTION_VIDEO_SIZE=1280x720
# MOTION_VIDEO_ASPECT_RATIO=16:9
# MOTION_POINT_COST=200
